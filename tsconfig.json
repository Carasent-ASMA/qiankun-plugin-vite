{
  "compilerOptions": {
    "alwaysStrict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": ["dom", "es2017"],
    "module": "esnext",
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "declaration": true,
    "strict": true,
    "target": "ES2019",
    "types": ["node"]
  },
  "exclude": ["node_modules"],
  "include": ["src/index.ts", "src/helper.ts", "type/**/*.d.ts", "vite.config.ts"]
}
